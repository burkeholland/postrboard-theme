{
  "name": "postrboard",
  "displayName": "Postrboard",
  "description": "A VS Code theme in light and dark variants, inspired by the PostrBoard.com color palette — coral, azure, and sage with WCAG AA accessible contrast.",
  "version": "0.1.2",
  "publisher": "burkeholland",
  "license": "MIT",
  "icon": "./images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/burkeholland/postrboard-theme"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "light",
    "dark",
    "color-theme",
    "postrboard",
    "coral",
    "azure",
    "accessible"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Postrboard",
        "uiTheme": "vs",
        "path": "./themes/Postrboard-color-theme.json"
      },
      {
        "label": "Postrboard Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/Postrboard Dark-color-theme.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
